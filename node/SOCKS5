const net = require('net');

// 💡 代理配置（请务必修改为强密码）
const USERNAME = 'admin';
const PASSWORD = 'password123';
const PORT = parseInt(process.env.SERVER_PORT || process.env.PORT || 3000);

const server = net.createServer((client) => {
    let state = 0; // 状态机：0=握手, 1=认证, 2=连接

    client.on('data', (data) => {
        if (state === 0) {
            // --- 阶段 1: 客户端握手 (Greeting) ---
            if (data[0] !== 0x05) return client.end(); // 只接受 SOCKS5 (0x05)
            
            // 回复客户端: SOCKS5 (0x05), 需要用户名密码认证 (0x02)
            client.write(Buffer.from([0x05, 0x02]));
            state = 1;
        } 
        else if (state === 1) {
            // --- 阶段 2: 账号密码认证 (RFC 1929) ---
            if (data[0] !== 0x01) return client.end(); // 认证子协议版本必须为 0x01

            // 解析用户名
            const ulen = data[1];
            const user = data.toString('utf8', 2, 2 + ulen);
            // 解析密码
            const plen = data[2 + ulen];
            const pass = data.toString('utf8', 3 + ulen, 3 + ulen + plen);

            if (user === USERNAME && pass === PASSWORD) {
                // 认证成功 (0x00)
                client.write(Buffer.from([0x01, 0x00]));
                state = 2;
                console.log(`[认证成功] 客户端 IP: ${client.remoteAddress}`);
            } else {
                // 认证失败 (0x01)
                client.write(Buffer.from([0x01, 0x01]));
                console.log(`[认证拦截] 失败尝试 - 账号: ${user}, 密码: ${pass}`);
                client.end();
            }
        } 
        else if (state === 2) {
            // --- 阶段 3: 处理目标连接请求 (Connect Request) ---
            // CMD = 0x01 (CONNECT), 我们这里只实现最核心的 TCP 连接
            if (data[0] !== 0x05 || data[1] !== 0x01) return client.end(); 

            const atyp = data[3]; // 地址类型
            let dstAddr = '';
            let offset = 0;

            if (atyp === 0x01) { 
                // IPv4 (4字节)
                dstAddr = `${data[4]}.${data[5]}.${data[6]}.${data[7]}`;
                offset = 8;
            } else if (atyp === 0x03) { 
                // 域名 (第1字节是长度，后面是内容)
                const domainLen = data[4];
                dstAddr = data.toString('utf8', 5, 5 + domainLen);
                offset = 5 + domainLen;
            } else {
                // 暂不支持 IPv6 (0x04) 以保持代码精简
                return client.end(); 
            }

            // 读取最后2字节作为端口 (大端序)
            const dstPort = data.readUInt16BE(offset);
            console.log(`[请求转发] 目标 -> ${dstAddr}:${dstPort}`);

            // 停止对当前 socket 的 data 监听，准备把控制权交给 pipe
            client.removeAllListeners('data');

            // 连接目标服务器
            const target = net.connect(dstPort, dstAddr, () => {
                // 告诉客户端：连接目标服务器成功
                client.write(Buffer.from([0x05, 0x00, 0x00, 0x01, 0, 0, 0, 0, 0, 0]));
                
                // 🚀 核心：双向流量管道 (全双工转发)
                client.pipe(target);
                target.pipe(client);
            });

            // --- 错误处理 (关键：防止云端 Node 进程崩溃) ---
            target.on('error', (err) => {
                console.log(`[目标连接失败] ${dstAddr}:${dstPort} - ${err.message}`);
                client.end();
            });
            client.on('error', () => {
                target.end();
            });
        }
    });

    // 捕获客户端突然断开的情况
    client.on('error', () => {}); 
});

server.listen(PORT, '0.0.0.0', () => {
    console.log(`🌐 监听地址: 0.0.0.0:${PORT}`);
});
