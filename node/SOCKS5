const net = require('net');

// 代理配置（请务必修改为强密码）
const USERNAME = 'admin';
const PASSWORD = 'password123';
const PORT = parseInt(process.env.SERVER_PORT || process.env.PORT || 3000);

const server = net.createServer((client) => {
    let state = 0;

    client.on('data', (data) => {
        if (state === 0) {
            if (data[0] !== 0x05) return client.end(); 
            
            client.write(Buffer.from([0x05, 0x02]));
            state = 1;
        } 
        else if (state === 1) {
            if (data[0] !== 0x01) return client.end();

            const ulen = data[1];
            const user = data.toString('utf8', 2, 2 + ulen);
            
            const plen = data[2 + ulen];
            const pass = data.toString('utf8', 3 + ulen, 3 + ulen + plen);

            if (user === USERNAME && pass === PASSWORD) {
                client.write(Buffer.from([0x01, 0x00]));
                state = 2;
            } else {
                client.write(Buffer.from([0x01, 0x01]));
                client.end();
            }
        } 
        else if (state === 2) {
            if (data[0] !== 0x05 || data[1] !== 0x01) return client.end(); 

            const atyp = data[3]; 
            let dstAddr = '';
            let offset = 0;

            if (atyp === 0x01) { 
                dstAddr = `${data[4]}.${data[5]}.${data[6]}.${data[7]}`;
                offset = 8;
            } else if (atyp === 0x03) { 
                const domainLen = data[4];
                dstAddr = data.toString('utf8', 5, 5 + domainLen);
                offset = 5 + domainLen;
            } else {
                return client.end(); 
            }

            const dstPort = data.readUInt16BE(offset);

            client.removeAllListeners('data');

            const target = net.connect(dstPort, dstAddr, () => {
                client.write(Buffer.from([0x05, 0x00, 0x00, 0x01, 0, 0, 0, 0, 0, 0]));
                
                client.pipe(target);
                target.pipe(client);
            });

            target.on('error', () => {
                client.end();
            });
            client.on('error', () => {
                target.end();
            });
        }
    });

    client.on('error', () => {}); 
});

server.listen(PORT, '0.0.0.0');
