const http = require('http'), https = require('https'), fs = require('fs'), fsPromises = fs.promises, path = require('path'), { spawn, exec } = require('child_process'), crypto = require('crypto'), util = require('util');
const execAsync = util.promisify(exec);

// ==============================================================================
//  1. 最小化配置与随机变量定义
// ==============================================================================
const PORT: parseInt(process.env.SERVER_PORT || process.env.PORT || 3000, 10),
const UUID = crypto.randomUUID();                       // 每次启动随机生成，无需保存
const WS_PATH = '/' + crypto.randomBytes(4).toString('hex'); // 随机 WebSocket 路径
const LINK_NAME = process.env.LINK_NAME || 'Argo-Node';

const XRAY_URL = 'https://github.com/XTLS/Xray-core/releases/latest/download/Xray-linux-64.zip';
const ARGO_URL = 'https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64';

const TMP_DIR = path.join(__dirname, '.temp_runtime');
const XRAY_BIN = path.join(TMP_DIR, 'xr_engine');
const ARGO_BIN = path.join(TMP_DIR, 'ag_tunnel');
const XRAY_ZIP = path.join(TMP_DIR, 'xr.zip');
const XRAY_CFG = path.join(TMP_DIR, 'cfg.json');

const activeProc = new Map();

// ==============================================================================
//  2. 极简极速下载函数
// ==============================================================================
const download = (url, dest) => new Promise((resolve, reject) => {
    const get = url.startsWith('https') ? https.get : http.get;
    get(url, { headers: { 'User-Agent': 'Mozilla/5.0' } }, res => {
        if (res.statusCode >= 300 && res.statusCode < 400 && res.headers.location) 
            return download(res.headers.location, dest).then(resolve).catch(reject);
        if (res.statusCode !== 200) return reject(`Status ${res.statusCode}`);
        const file = fs.createWriteStream(dest);
        res.pipe(file);
        file.on('finish', () => file.close(resolve));
    }).on('error', reject).setTimeout(20000, reject);
});

// 极简守护进程：挂了自动重启
const guard = (name, bin, args, stdio, onStart) => {
    const child = spawn(bin, args, { stdio, env: process.env });
    activeProc.set(name, child);
    if (onStart) onStart(child);
    child.on('exit', () => {
        activeProc.delete(name);
        setTimeout(() => fs.existsSync(bin) && guard(name, bin, args, stdio, onStart), 5000);
    });
};

// ==============================================================================
//  3. 核心运行流程
// ==============================================================================
(async () => {
    // 环境初始化
    try { await fsPromises.rm(TMP_DIR, { recursive: true, force: true }); } catch{}
    await fsPromises.mkdir(TMP_DIR, { recursive: true });

    try {
        console.log('⚡ Fetching binaries...');
        await Promise.all([download(XRAY_URL, XRAY_ZIP), download(ARGO_URL, ARGO_BIN)]);

        // 解压并提权
        await execAsync(`unzip -o ${XRAY_ZIP} -d ${TMP_DIR}`);
        const files = await fsPromises.readdir(TMP_DIR);
        const realXray = files.find(f => f.toLowerCase() === 'xray');
        if (!realXray) throw 'No Xray';

        await fsPromises.rename(path.join(TMP_DIR, realXray), XRAY_BIN);
        await fsPromises.chmod(XRAY_BIN, 0o755);
        await fsPromises.chmod(ARGO_BIN, 0o755);

        // 瞬间清理压缩包垃圾
        await fsPromises.rm(XRAY_ZIP, { force: true });

        // 生成 VLESS WebSocket 配置
        await fsPromises.writeFile(XRAY_CFG, JSON.stringify({
            log: { loglevel: 'none' },
            inbounds: [{ port: PORT, protocol: 'vless', settings: { clients: [{ id: UUID }], decryption: "none" }, streamSettings: { network: "ws", wsSettings: { path: WS_PATH } } }],
            outbounds: [{ protocol: 'freedom', streamSettings: { sockopt: { tcpcongestion: 'bbr' } } }]
        }));

        // 启动 Xray
        guard('Xray', XRAY_BIN, ['-c', XRAY_CFG], 'ignore');

        // 启动 Argo 临时隧道并捕获日志中的 trycloudflare 域名
        guard('Argo', ARGO_BIN, ['tunnel', '--protocol', 'http2', '--url', `http://localhost:${PORT}`, '--no-tls-verify'], ['ignore', 'ignore', 'pipe'], (child) => {
            child.stderr.on('data', d => {
                const match = d.toString().match(/(https:\/\/[a-z0-9-]+\.trycloudflare\.com)/);
                if (match) {
                    const domain = match[1].replace('https://', '');
                    const vlessLink = `vless://${UUID}@www.visa.com.sg:443?security=tls&sni=${domain}&fp=firefox&type=ws&path=${encodeURIComponent(WS_PATH)}#${LINK_NAME}`;
                    
                    console.log('\n==================================================');
                    console.log(`📋 VLESS Node Link:\n\n${vlessLink}`);
                    console.log('==================================================\n');
                }
            });
        });

    } catch (e) {
        console.error('💥 Init failed:', e);
        process.exit(1);
    }
})();

// 优雅退出机制：在平台回收、重启、拔线时彻底销毁现场，不留任何痕迹
const cleanUp = () => {
    for (const [name, child] of activeProc.entries()) {
        child.removeAllListeners('exit');
        child.kill('SIGKILL');
    }
    try { fs.rmSync(TMP_DIR, { recursive: true, force: true }); } catch{}
    process.exit(0);
};
process.on('SIGTERM', cleanUp).on('SIGINT', cleanUp);
