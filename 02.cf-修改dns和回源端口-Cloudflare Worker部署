      label { font-weight: 600; display: block; margin-top: 14px; color: #475569; font-size: 0.85rem; }
      input { width: 100%; padding: 11px; margin-top: 6px; border: 1px solid #cbd5e1; border-radius: 8px; box-sizing: border-box; background: #fff; font-size: 0.95rem; transition: all 0.2s; }
      input:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.1); outline: none; }
      
      /* 输入框组合，集成了一键复制按钮 */
      .input-group { display: flex; align-items: center; margin-top: 6px; }
      .input-group input { border-top-right-radius: 0; border-bottom-right-radius: 0; margin-top: 0; flex: 1; }
      .input-group-addon { padding: 11px 14px; background: #f1f5f9; border: 1px solid #cbd5e1; border-left: none; color: #64748b; font-size: 0.9rem; white-space: nowrap; font-weight: 500; }
      
      /* 精美复制小按钮 */
      .copy-btn { 
        padding: 11px 12px; 
        background: #f1f5f9; 
        border: 1px solid #cbd5e1; 
        border-left: none; 
        border-top-right-radius: 8px; 
        border-bottom-right-radius: 8px; 
        color: #2563eb; 
        cursor: pointer; 
        display: flex; 
        align-items: center; 
        justify-content: center;
        transition: all 0.2s;
      }
      .copy-btn:hover { background: #e2e8f0; color: #1d4ed8; }
      
      .tip-text { font-size: 0.8rem; color: #2563eb; margin-top: 6px; display: none; font-weight: 500; background: #eff6ff; padding: 6px 10px; border-radius: 6px; border-left: 3px solid #2563eb; }
      
      button.btn-primary { width: 100%; padding: 12px; margin-top: 20px; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; background: #2563eb; color: white; font-size: 0.95rem; transition: background 0.2s; }
      button.btn-primary:hover { background: #1d4ed8; }
      
      table { width: 100%; border-collapse: collapse; margin-top: 8px; }
      th { text-align: left; padding: 10px 12px; color: #64748b; font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 2px solid #f1f5f9; }
      td { padding: 14px 12px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
      tr:hover td { background-color: #fafafa; }
      
      .domain-title { font-weight: 600; color: #1e293b; font-size: 0.95rem; word-break: break-all; }
      .domain-content { color: #64748b; font-size: 0.85rem; margin-top: 4px; display: flex; align-items: center; gap: 6px; word-break: break-all; }
      
      .tag { display: inline-block; padding: 2px 8px; border-radius: 6px; font-size: 0.75rem; font-weight: 700; line-height: 1.4; }
      .tag-a { background: #dbeafe; color: #1e40af; }
      .tag-cname { background: #fef3c7; color: #92400e; }
      .tag-green { background: #dcfce7; color: #166534; font-weight: 600; }
      .tag-default { background: #f1f5f9; color: #475569; }
      
      .btn-danger { background: #fee2e2; color: #991b1b; padding: 6px 14px; font-size: 0.8rem; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
      .btn-danger:hover { background: #fca5a5; color: #7f1d1d; }
    </style>
    <script>
      // 实时获取拼接好的完整域名
      function getFullDomainValue() {
        const prefixInput = document.getElementById('domain-prefix-input');
        const prefix = prefixInput ? prefixInput.value.trim() : '';
        const suffix = "${currentZoneName}";
        
        if (prefix === '@' || prefix === '') {
          return suffix;
        } else if (prefix.endsWith('.' + suffix)) {
          return prefix;
        } else {
          return prefix + '.' + suffix;
        }
      }

      function handleSubmit(form) {
        form.elements['fulldomain'].value = getFullDomainValue();
        return true;
      }

      // 一键复制完整域名并显示勾选状态
      async function copyFullDomain(btn) {
        const fullDomain = getFullDomainValue();
        try {
          await navigator.clipboard.writeText(fullDomain);
          const originalHtml = btn.innerHTML;
          // 变成勾选图标 (SVG)
          btn.innerHTML = '<svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425z"/></svg>';
          btn.style.color = '#166534';
          btn.style.background = '#dcfce7';
          setTimeout(() => {
            btn.innerHTML = originalHtml;
            btn.style.color = '#2563eb';
            btn.style.background = '#f1f5f9';
          }, 1500);
        } catch (err) {
          alert('复制失败：' + err);
        }
      }

      function handleTargetInput(val) {
        const tip = document.getElementById('port-tip');
        const portInput = document.getElementById('port-input');
        if (val.includes(':')) {
          const parts = val.split(':');
          const port = parts[parts.length - 1];
          if(port && !isNaN(port)) {
            tip.innerText = '💡 已智能识别目标端口 :' + port + '，下方无需重复填写。';
            tip.style.display = 'block';
            portInput.placeholder = '已在目标中携带端口';
            portInput.required = false;
            return;
          }
        }
        tip.style.display = 'none';
        portInput.placeholder = '例如: 8080';
        portInput.required = true;
      }
    </script>
  </head>
  <body>
    <div class="header">
        <h2>DNS & 端口管理器</h2>
        <a href="/?logout=true" class="logout-btn">安全退出</a>
    </div>

    <div class="zone-selector">
        <label>当前代管域名 (Zone)</label>
        <select onchange="window.location.href='/?zoneId='+this.value">
            ${zones.map(z => `<option value="${z.id}" ${z.id === currentZoneId ? 'selected' : ''}>${z.name}</option>`).join('')}
        </select>
    </div>

    <div class="card">
      <h3>新建 / 更新解析 (${currentZoneName})</h3>
      <form method="POST" onsubmit="return handleSubmit(this)">
        <input type="hidden" name="action" value="update">
        <input type="hidden" name="zoneId" value="${currentZoneId}">
        <input type="hidden" name="fulldomain" value="">
        
        <label>主机记录 (Hostname)</label>
        <div class="input-group">
          <input type="text" id="domain-prefix-input" name="domain_prefix" placeholder="如 app (填 @ 或留空为主域名)" required>
          <span class="input-group-addon">.${currentZoneName}</span>
          <button type="button" class="copy-btn" title="复制完整域名" onclick="copyFullDomain(this)">
            <svg width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M4 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zM2 5a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-1h1v1a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h1v1z"/>
            </svg>
          </button>
        </div>
        
        <label>目标地址 (Target)</label>
        <input type="text" name="target" oninput="handleTargetInput(this.value)" placeholder="支持 1.2.3.4 或 1.2.3.4:30426" required>
        <div id="port-tip" class="tip-text"></div>
        
        <label>回源端口 (选填)</label>
        <input type="number" id="port-input" name="port" placeholder="例如: 8080" required>
        
        <button type="submit" class="btn-primary">应用配置</button>
      </form>
    </div>

    <div class="card">
      <h3>活跃配置列表 (${listData.length})</h3>
      ${listData.length === 0 ? '<p style="color:#94a3b8; text-align:center; margin: 2rem 0;">当前域名下暂无解析记录</p>' : `
      <table>
        <thead>
          <tr>
            <th>域名与内容</th>
            <th>端口规则</th>
            <th style="text-align:right">操作</th>
          </tr>
        </thead>
        <tbody>
          ${listData.map(item => `
          <tr>
            <td>
              <div class="domain-title">${item.domain}</div>
              <div class="domain-content">
                <span class="tag ${item.type === 'CNAME' ? 'tag-cname' : 'tag-a'}">${item.type}</span>
                ${item.content}
              </div>
            </td>
            <td>
              ${item.port 
                ? `<span class="tag tag-green">➡ :${item.port}</span>` 
                : `<span class="tag tag-default">默认端口</span>`}
            </td>
            <td style="text-align:right">
              <form method="POST" onsubmit="return confirm('确认要彻底删除 ${item.domain} 及其端口规则吗？');" style="display:inline;">
                <input type="hidden" name="action" value="delete">
                <input type="hidden" name="zoneId" value="${currentZoneId}">
                <input type="hidden" name="dnsId" value="${item.dnsId || ''}">
                <input type="hidden" name="ruleId" value="${item.ruleId || ''}">
                <input type="hidden" name="rulesetId" value="${item.rulesetId || ''}">
                <input type="hidden" name="domain" value="${item.domain}">
                <button type="submit" class="btn-danger">删除</button>
              </form>
            </td>
          </tr>
          `).join('')}
        </tbody>
      </table>
      `}
    </div>
  </body>
  </html>
  `;
}

function resultHtml(logs, zoneId) {
  return `
  <!DOCTYPE html>
  <html>
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
      body { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; max-width: 600px; margin: 3rem auto; padding: 0 1rem; background: #f8fafc; color: #1e293b; }
      .box { background: white; padding: 24px; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02); border: 1px solid #e2e8f0; }
      h3 { margin-top: 0; color: #0f172a; font-size: 1.2rem; font-weight: 700; margin-bottom: 1rem; }
      ul { padding-left: 0; list-style: none; margin: 0; }
      li { margin-bottom: 8px; padding: 10px 12px; background: #f8fafc; border-left: 4px solid #2563eb; border-radius: 0 6px 6px 0; font-size: 0.9rem; color: #334155; }
      a { display: block; text-align: center; margin-top: 24px; text-decoration: none; background: #0f172a; color: white; padding: 12px; border-radius: 8px; font-size: 0.95rem; font-weight: 600; transition: background 0.2s; }
      a:hover { background: #1e293b; }
    </style>
  </head>
  <body>
    <div class="box">
      <h3>⚙️ 任务执行日志</h3>
      <ul>${logs.map(l => `<li>${l}</li>`).join('')}</ul>
      <a href="/?zoneId=${zoneId}">返回控制台</a>
    </div>
  </body>
  </html>`;
}
